# --- Database -----------------------------------------------------------------
# Local Postgres from docker-compose (default). Override to point at Neon etc.
DATABASE_URL=postgresql+asyncpg://eigg:eigg@localhost:5433/eigg_prevent
# Set true for managed Postgres (Neon) where TLS is required. Local docker = false.
DB_SSL=false

# --- App ----------------------------------------------------------------------
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3001

# --- LLM ----------------------------------------------------------------------
# mock | anthropic | azure | bedrock | ollama   (mock needs no credentials)
LLM_PROVIDER=mock

# anthropic
# ANTHROPIC_API_KEY=

# azure openai
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# aws bedrock (uses standard AWS_* env / instance role)
# AWS_BEDROCK_REGION=eu-west-2
# AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# ollama (self-hosted)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:70b

# --- Admin / platform --------------------------------------------------------
# Public URL of the frontend (used to build invite links).
APP_BASE_URL=http://localhost:3001
# Shared secret between the Next.js admin proxy and this backend. MUST match the
# frontend's INTERNAL_API_SECRET. Change in production.
INTERNAL_API_SECRET=dev-internal-secret-change-me
# Seeded platform super-admin (the first-deploy backdoor into /admin).
ADMIN_EMAIL=admin@eigg.co.uk
ADMIN_PASSWORD=eigg-admin

# --- Email (invites) ---------------------------------------------------------
# If RESEND_API_KEY is unset, invites are stubbed (the link is logged to the server).
# RESEND_API_KEY=
EMAIL_FROM=EIGG <noreply@eigg.co.uk>
