# Browser + server-side base URL for the EIGG Prevent backend.
NEXT_PUBLIC_API_URL=http://localhost:8001
API_URL=http://localhost:8001

# --- Auth (NextAuth) ----------------------------------------------------------
# Public URL of this frontend. Required by NextAuth.
NEXTAUTH_URL=http://localhost:3001
# Signing secret for session JWTs. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production

# Shared-password fallback (small deployments with no IdP).
# Login is DISABLED unless AUTH_PASSWORD or OIDC_ISSUER is set.
AUTH_PASSWORD=eigg

# OIDC SSO (Google / Okta / Auth0 / Azure AD). Leave blank to use password only.
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_PROVIDER_NAME=SSO

# --- Admin proxy -------------------------------------------------------------
# Shared secret for the server-side /api/admin proxy → backend. Must match the
# backend's INTERNAL_API_SECRET.
INTERNAL_API_SECRET=dev-internal-secret-change-me
