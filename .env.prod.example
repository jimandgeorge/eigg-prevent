# EIGG Prevent — production env. Copy to `.env` on the droplet and fill in.
# docker compose reads `.env` for both ${VAR} interpolation and env_file injection.

# --- Database (the bundled Postgres service) ---------------------------------
POSTGRES_USER=eigg
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=eigg_prevent
DATABASE_URL=postgresql+asyncpg://eigg:CHANGE_ME_strong_db_password@db:5432/eigg_prevent
DB_SSL=false

# --- App ----------------------------------------------------------------------
ENVIRONMENT=production
APP_BASE_URL=https://prevent.eigg.io
CORS_ORIGINS=https://prevent.eigg.io

# --- Auth (NextAuth, frontend) ------------------------------------------------
NEXTAUTH_URL=https://prevent.eigg.io
NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32
# Optional shared-password login; leave unset to require real accounts/OIDC only.
# AUTH_PASSWORD=
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_PROVIDER_NAME=SSO

# --- Internal admin proxy <-> backend (MUST match on both) --------------------
INTERNAL_API_SECRET=CHANGE_ME_run_openssl_rand_hex_32

# --- Platform super-admin (seeded on boot — the first-deploy backdoor) --------
ADMIN_EMAIL=admin@eigg.io
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- Frontend -> backend (server-side, internal docker network) ---------------
API_URL=http://backend:8001
# Build-time, browser-facing. Empty = same-origin (/api/v1 via nginx). Leave blank.
NEXT_PUBLIC_API_URL=

# --- LLM (gap analysis, drafting, onboarding) ---------------------------------
# mock works with no key. For real AI set anthropic + key.
LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=

# --- Email (invites) ----------------------------------------------------------
# Without RESEND_API_KEY invites are stubbed (link logged). For real emails, verify
# eigg.io in Resend and set the key.
# RESEND_API_KEY=
EMAIL_FROM=EIGG <noreply@eigg.io>
