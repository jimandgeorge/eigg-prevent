# EIGG Prevent — self-host config. Copy to `.env` and fill in.
# Generate secrets:  openssl rand -base64 32   and   openssl rand -hex 32

# Public URL where users reach EIGG Prevent (used for sign-in + invite links).
# Internal HTTP install example: http://eigg.your-company.internal
PUBLIC_URL=http://localhost
HTTP_PORT=80

# Pin a version instead of latest for reproducible installs, e.g. v1.0.0
IMAGE_TAG=latest

# --- Database (bundled Postgres) ----------------------------------------------
DB_USER=eigg
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=eigg_prevent

# --- Secrets ------------------------------------------------------------------
NEXTAUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32
INTERNAL_API_SECRET=CHANGE_ME_run_openssl_rand_hex_32   # used internally; not exposed

# --- First admin (seeded on first boot — your way into /admin) ----------------
ADMIN_EMAIL=admin@your-company.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Optional shared-password login in addition to accounts. Leave blank to require accounts.
AUTH_PASSWORD=

# --- AI provider --------------------------------------------------------------
# mock = works with no AI (gap analysis/drafting are stubbed).
# anthropic = cloud Claude (set ANTHROPIC_API_KEY). ollama = fully on-prem (set OLLAMA_BASE_URL).
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=

# --- Email (invites) — optional. Without it, invite links are shown in the admin UI.
RESEND_API_KEY=
EMAIL_FROM=EIGG <noreply@eigg.io>
